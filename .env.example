# Backend Configuration
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://admin:senha_segura@localhost:5432/secult_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=secult_db
DB_USER=admin
DB_PASSWORD=senha_segura

# Authentication
JWT_SECRET=sua_chave_secreta_super_segura_aqui_com_muitos_caracteres
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=chave_refresh_super_segura_aqui

# Encryption
ENCRYPTION_KEY=sua_chave_de_criptografia_de_32_caracteres

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_ou_app_password
SMTP_FROM=noreply@secult.gov.br

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# External APIs
ESMAISCRIATIVO_URL=https://esmaiscriativo.es.gov.br
SCRAPING_ENABLED=true

# Redis
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Feature Flags
OFFLINE_MODE_ENABLED=true
RBAC_ENABLED=true
LGPD_COMPLIANCE_ENABLED=true
